# Havstund — miljøvariabler (kopier til .env lokalt; sett dem i Railway i prod)

# PostgreSQL. Railway setter denne automatisk når du legger til Postgres-plugin.
DATABASE_URL=postgres://bruker:passord@host:5432/havstund

# Hemmelig nøkkel for innlogging (JWT). Bruk en lang tilfeldig streng (>= 32 tegn) i prod.
# Ekte verdier settes i Railway env — aldri sjekk dem inn i git.
JWT_SECRET=CHANGE_ME_min_32_tegn_tilfeldig

# Admin-bruker som lages ved første oppstart. Ekte verdi settes i Railway, ikke her.
ADMIN_EPOST=admin@havstund.no
ADMIN_PASSWORD=CHANGE_ME

# Sett til production i Railway (sikrer cookie m.m.)
NODE_ENV=development
