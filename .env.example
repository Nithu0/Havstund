# Havstund — miljøvariabler (kopier til .env lokalt; sett dem i Railway i prod)

# PostgreSQL. Railway setter denne automatisk når du legger til Postgres-plugin.
DATABASE_URL=postgres://bruker:passord@host:5432/havstund

# Hemmelig nøkkel for innlogging (JWT). Bruk en lang tilfeldig streng i prod.
JWT_SECRET=bytt-meg-til-noe-langt-og-tilfeldig

# Admin-bruker som lages ved første oppstart
ADMIN_EPOST=admin@havstund.no
ADMIN_PASSWORD=havstund2026

# Sett til production i Railway (sikrer cookie m.m.)
NODE_ENV=development
