# Havstund Brain — miljøvariabler. Kopier til .env (aldri commit .env).
# config.ts feiler raskt (zod) ved oppstart hvis påkrevde mangler.

# Claude / Anthropic — KUN i brain-prosessen, aldri i nettsidens env eller git.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-opus-4-8

# Nettsidens REST-API som brain kaller (HttpWebsiteAdapter).
WEBSITE_BASE_URL=http://localhost:3000
# Service-token som nettsiden mapper til den smale 'agent'-rollen.
WEBSITE_SERVICE_TOKEN=change-me-service-token-min-16-chars

# Operatør-token: nettside-shimen sender denne til brain /agent/ask.
BRAIN_OPERATOR_TOKEN=change-me-operator-token-min-16-chars

# Postgres for brain-eide tabeller (pending_actions, lessons, audit).
# Kan peke på samme database som nettsiden — brain bruker egne tabeller.
DATABASE_URL=postgres://user:pass@localhost:5432/havstund

# HTTP-server
PORT=4000

# Logg-nivå (pino): trace|debug|info|warn|error
LOG_LEVEL=info

# Bekreft-handshake TTL i minutter (CONFIRM_TTL).
CONFIRM_TTL_MIN=15

# Skygge-modus: når 'false' treffer skrive-verktøy ALDRI porten (dry-run).
# Standard true betyr at /confirm faktisk kan utføre skriving.
BRAIN_ALLOW_WRITES=true
