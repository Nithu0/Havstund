{
  "name": "havstund-brain",
  "version": "0.1.0",
  "description": "Havstund Brain — pluggbar AI-agent med lærings-hjerne. Egen prosess, snakker med nettsidens REST-API over service-token. Av/på utenfor nettsidens hot path.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').copyFileSync('src/brain/migrations.sql','dist/src/brain/migrations.sql')\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "nightly:contract": "vitest run test/contract-live.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.65.0",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "undici": "7.28.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/pg": "8.11.10",
    "eslint": "9.17.0",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.2",
    "vitest": "2.1.8"
  }
}
